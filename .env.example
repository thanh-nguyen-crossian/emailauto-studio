# Anthropic API key — server-side only. Copy to .env.local and fill in.
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI / ChatGPT API key — server-side only. Used when selecting ChatGPT models.
OPENAI_API_KEY=sk-proj-...

# Gemini API key — server-side only. Used when selecting Gemini models.
GEMINI_API_KEY=AIza...

# Optional — per-provider generation timeout in milliseconds. Defaults to 145000.
AI_PROVIDER_TIMEOUT_MS=145000
# Optional — segment patch calls use a shorter timeout so retries cannot burn the full route budget.
AI_PATCH_PROVIDER_TIMEOUT_MS=60000
# Optional — stream server progress to the Studio UI. Default true.
AI_GENERATION_STREAMING=true
# Optional — stop launching new work near this deadline and return usable partials instead.
AI_SOFT_DEADLINE_MS=240000
# Optional — Claude uses streaming by default to avoid long non-streaming operation failures.
AI_CLAUDE_STREAMING=true
# Optional — retry transient provider overload/rate-limit errors before salvaging partial output.
AI_PROVIDER_RETRIES=2
AI_PROVIDER_RETRY_BASE_MS=900
# Optional — legacy full-brief provider output budget. Defaults to 18000; capped at 64000.
AI_MAX_OUTPUT_TOKENS=18000
# Optional — shared foundation output budget. Segment copy is generated separately.
AI_FOUNDATION_OUTPUT_TOKENS=9000
# Optional — per-user/IP generation requests allowed per minute. Set 0 to disable.
AI_GENERATE_RATE_LIMIT_PER_MIN=6

# Optional — model sampling for copy generation. Higher B temp helps A/B contrast.
AI_TEMP_A=0.85
AI_TEMP_B=1.0
AI_TEMP_B_RETRY=0.9
AI_TOP_P=0.95
# Optional — set on/true for older full-brief generation only; layered foundations already run in parallel.
AI_AB_FAST_PARALLEL=off
# Optional — structured per-stage server logs. AI_PROMPT_DEBUG=on also enables this.
AI_GENERATION_TELEMETRY=off

# Optional — one targeted repair pass for low-scoring/playbook-drifting generations.
# Set AI_QUALITY_REPAIR=off to disable. Threshold defaults to 78; repair temp defaults to 0.6.
AI_QUALITY_REPAIR=on
AI_QUALITY_REPAIR_THRESHOLD=78
AI_REPAIR_TEMP=0.6

# Optional — split generation into shared foundation + small segment copy patches.
# Defaults: layered mode at 1+ segments; adaptive batch/concurrency by selected model speed unless overridden.
AI_SEGMENT_BATCH_THRESHOLD=1
# AI_SEGMENT_BATCH_SIZE=1
# AI_SEGMENT_BATCH_CONCURRENCY=2

# SendGrid API key — server-side only. Needs Marketing → Read/Write (for /v3/designs).
SENDGRID_API_KEY=SG.xxxx
# Optional — signed Event Webhook public key from SendGrid/Twilio. Required for /api/webhooks/sendgrid.
SENDGRID_EVENT_WEBHOOK_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----...
# Optional — salt used before hashing recipient emails from webhook events.
SENDGRID_EVENT_EMAIL_HASH_SALT=replace-with-random-secret

# Supabase — for auth (email/password) + saved-version history. Browser-safe (anon key).
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...   # or sb_publishable_...

# Supabase service-role / secret key — SERVER-ONLY (admin: approve users, reset passwords,
# activate/deactivate). Never prefix with NEXT_PUBLIC. From Settings → API Keys → secret.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...   # or the service_role eyJ... JWT

# Google Sheet tracking webhook — SERVER-ONLY. Auto-fills the team sheet ("templates" tab)
# after each SendGrid push. Deploy docs/apps-script-sheet-webhook.gs on the sheet, paste the
# Web app /exec URL here; SECRET must match the constant in that script. Unset = feature off.
SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/xxxx/exec
SHEETS_WEBHOOK_SECRET=random-shared-secret
