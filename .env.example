# Anthropic API key — server-side only. Copy to .env.local and fill in.
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI / ChatGPT API key — server-side only. Used when selecting ChatGPT models.
OPENAI_API_KEY=sk-proj-...

# Gemini API key — server-side only. Used when selecting Gemini models.
GEMINI_API_KEY=AIza...

# SendGrid API key — server-side only. Needs Marketing → Read/Write (for /v3/designs).
SENDGRID_API_KEY=SG.xxxx

# Supabase — for auth (email/password) + saved-version history. Browser-safe (anon key).
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...   # or sb_publishable_...

# Supabase service-role / secret key — SERVER-ONLY (admin: approve users, reset passwords,
# activate/deactivate). Never prefix with NEXT_PUBLIC. From Settings → API Keys → secret.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...   # or the service_role eyJ... JWT
